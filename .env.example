# Copy this file to .env and fill in your real values.
# Do not commit actual secrets to source control.

PORT=5000

# Prisma database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/guardian_shield"

# Authentication
JWT_SECRET=replace-with-a-secure-jwt-secret

# Client / CORS
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# AWS S3 backup storage
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=guardianshield-audit-checkpoints
S3_PREFIX=guardianshield/users
S3_ENDPOINT=
S3_SERVER_SIDE_ENCRYPTION=AES256
